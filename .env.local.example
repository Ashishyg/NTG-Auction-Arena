# Same Neon DB as the main NTG site (auction branch in prod)
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
# Optional: direct (non-pooled) URL, used by migrations only
DIRECT_URL="postgresql://user:pass@host/db?sslmode=require"

# Shared secret with the main site so its tokens verify here
JWT_SECRET="change-me-must-match-main-site"

# Where the main NTG site lives (for redirects / CORS)
MAIN_SITE_URL="https://ntg.example.com"

PORT=3001
